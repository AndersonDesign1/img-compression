---
import BaseLayout from "@/layouts/base-layout.astro";
import { SITE_PERSONAL_URL, SITE_REPO_URL } from "@/lib/utils/site";
---

<BaseLayout
  title="About — PixelPress"
  description="Why PixelPress exists and what it does."
>
  <section class="grid gap-8">
    <div class="max-w-[42rem] space-y-4">
      <p class="text-[0.72rem] uppercase tracking-[0.18em] text-white/40">
        Why I built this
      </p>
      <h1
        class="max-w-[14ch] font-display text-[clamp(2rem,4vw,3.2rem)] leading-[1.02] tracking-[-0.05em] text-text"
      >
        I wanted something quieter than the existing tools.
      </h1>
      <p class="text-[1rem] leading-7 text-white/58">
        TinyPNG is useful until you hit the free-tier ceiling. Squash used to be
        a nice option, but it is no longer maintained. I wanted one quiet tool
        for screenshots, exports, product images, and handoff assets that could
        handle more than a tiny batch.
      </p>
      <p class="text-[1rem] leading-7 text-white/58">
        PixelPress runs in the browser, uses jSquash and web workers, and keeps
        the whole job on your machine.
      </p>
      <div class="flex flex-wrap gap-4 text-sm text-white/68">
        <a
          class="underline decoration-white/15 underline-offset-4 hover:decoration-white/55 hover:text-text"
          href={SITE_REPO_URL}
          target="_blank"
          rel="noreferrer"
        >
          GitHub
        </a>
        <a
          class="underline decoration-white/15 underline-offset-4 hover:decoration-white/55 hover:text-text"
          href={SITE_PERSONAL_URL}
          target="_blank"
          rel="noreferrer"
        >
          andersonjoseph.com
        </a>
      </div>
    </div>
  </section>

  <section class="grid gap-4 border-t border-border pt-5">
    <p class="text-[0.72rem] uppercase tracking-[0.18em] text-white/40">
      What matters
    </p>
    <div
      class="grid gap-3 text-[0.98rem] leading-7 text-white/58 sm:grid-cols-2"
    >
      <p>Local-first. Batch compression. Format conversion.</p>
      <p>
        Built with jSquash, web workers, and a simple React app inside Astro.
      </p>
    </div>
  </section>
</BaseLayout>
